<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LibraryApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LibraryApp.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="Библиотека">

    <FlyoutItem Title="Главное" Icon="icon_about.png">
        <Tab Title="Каталог" Icon="icon_feed.png">
            <ShellContent ContentTemplate="{DataTemplate views:CatalogPage}" />
        </Tab>

        <Tab Title="Читатели" Icon="icon_about.png">
            <ShellContent ContentTemplate="{DataTemplate views:ReadersPage}" />
        </Tab>

        <Tab Title="Добавить книгу" Icon="icon_about.png">
            <ShellContent ContentTemplate="{DataTemplate views:AddBookPage}" />
        </Tab>

        <Tab Title="Добавить читателя" Icon="icon_about.png">
            <ShellContent ContentTemplate="{DataTemplate views:AddReaderPage}" />
        </Tab>

        <Tab Title="Выдать книгу" Icon="icon_about.png">
            <ShellContent ContentTemplate="{DataTemplate views:IssueBookPage}" />
        </Tab>
    </FlyoutItem>
</Shell>