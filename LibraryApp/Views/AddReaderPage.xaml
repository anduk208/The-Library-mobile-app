<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryApp.Views.AddReaderPage"
             Title="Добавить читателя"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Регистрация нового читателя" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Black" />

            <VerticalStackLayout Spacing="5">
                <Label Text="ФИО" TextColor="Black" FontAttributes="Bold" />
                <Entry x:Name="EntryFullName" Placeholder="Иванов Иван Иванович" TextColor="Black" PlaceholderColor="Gray" BackgroundColor="#F5F5F5" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Номер читательского билета" TextColor="Black" FontAttributes="Bold" />
                <Entry x:Name="EntryCardNumber" Placeholder="12345" Keyboard="Numeric" TextColor="Black" PlaceholderColor="Gray" BackgroundColor="#F5F5F5" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Контактный телефон" TextColor="Black" FontAttributes="Bold" />
                <Entry x:Name="EntryPhone" Placeholder="+7(999)000-00-00" Keyboard="Telephone" TextColor="Black" PlaceholderColor="Gray" BackgroundColor="#F5F5F5" />
            </VerticalStackLayout>

            <Button Text="Зарегистрировать читателя" Clicked="OnRegisterReaderClicked" BackgroundColor="#2C3E50" TextColor="White" CornerRadius="8" FontSize="18" FontAttributes="Bold" HeightRequest="55" />

            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" Color="#2C3E50" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>